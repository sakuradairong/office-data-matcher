{
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "[go]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": false,
    "editor.formatOnSave": true
  },
  "[vue]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "search.exclude": {
    "frontend/dist": true,
    "build": true,
    "node_modules": true
  }
}
